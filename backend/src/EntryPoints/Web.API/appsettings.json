{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Database": ""
  },
  "Auth": {
    "Authority": "",
    "IntrospectionEndpoint": "",
    "IntrospectionClientId": "",
    "IntrospectionClientSecret": ""
  },
  "Redis": {
    "ConnectionString": ""
  },
  "IntrospectionCache": {
    "TtlSeconds": 30
  },
  "RabbitMq": {
    "Host": "",
    "Port": 5672,
    "User": "",
    "Password": "",
    "VirtualHost": "/",
    "ExchangeName": "sample.exchange",
    "QueueName": "sample.queue",
    "RoutingKey": "sample.key"
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "ServerUrl": "http://seq:5341" }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  }
}
