{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ConnectionStrings": {
    "Database": ""
  },
  "Jwt": {
    "Secret": "",
    "Issuer": "base-scaffold",
    "Audience": "base-scaffold-clients"
  },
  "RabbitMq": {
    "Host": "",
    "Port": 5672,
    "User": "",
    "Password": "",
    "VirtualHost": "/",
    "ExchangeName": "sample.exchange",
    "QueueName": "sample.queue",
    "RoutingKey": "sample.key"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": { "Default": "Information" },
    "WriteTo": [
      { "Name": "Console" },
      { "Name": "Seq", "Args": { "ServerUrl": "http://seq:5341" } }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  }
}
