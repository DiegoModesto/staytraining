@page "/admin/users"
@attribute [Authorize]
@inject IAdminGatewayClient Client
@inject IDialogService DialogService
@inject NavigationManager Nav

<PageTitle>Users</PageTitle>

<PermissionView Permission="users.read">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
        <MudText Typo="Typo.h4">Users</MudText>
        <MudSpacer />
        <PermissionView Permission="users.write">
            <MudButton Color="Color.Primary" Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.PersonAdd" OnClick="OpenPreProvision">
                Pre-provision
            </MudButton>
        </PermissionView>
    </MudStack>

    @if (_error is not null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-3">@_error</MudAlert>
    }

    <MudTextField @bind-Value="_search" Placeholder="Search by email/name" Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true"
                  DebounceInterval="300" OnDebounceIntervalElapsed="@(async () => await ReloadAsync())" Class="mb-3" />

    <MudDataGrid T="UserSummary" ServerData="@LoadUsers" @ref="_grid" RowsPerPage="20">
        <Columns>
            <PropertyColumn Property="x => x.Email" Title="Email" />
            <PropertyColumn Property="x => x.DisplayName" Title="Display name" />
            <TemplateColumn Title="Active">
                <CellTemplate>@(context.Item.IsActive ? "Yes" : "No")</CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="">
                <CellTemplate>
                    <MudButton Href="@($"/admin/users/{context.Item.Id}")" Variant="Variant.Outlined" Size="Size.Small">View</MudButton>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent>
            <MudDataGridPager T="UserSummary" />
        </PagerContent>
    </MudDataGrid>
</PermissionView>

@code {
    private MudDataGrid<UserSummary>? _grid;
    private string? _search;
    private string? _error;

    private async Task<GridData<UserSummary>> LoadUsers(GridState<UserSummary> state)
    {
        try
        {
            _error = null;
            PagedResponse<UserSummary> page = await Client.ListUsersAsync(state.Page + 1, state.PageSize, _search, CancellationToken.None);
            return new GridData<UserSummary> { Items = page.Items, TotalItems = page.Total };
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            return new GridData<UserSummary> { Items = Array.Empty<UserSummary>(), TotalItems = 0 };
        }
    }

    private async Task ReloadAsync()
    {
        if (_grid is not null)
        {
            await _grid.ReloadServerData();
        }
    }

    private async Task OpenPreProvision()
    {
        IDialogReference dlg = await DialogService.ShowAsync<Dialogs.PreProvisionUserDialog>("Pre-provision user");
        DialogResult? result = await dlg.Result;
        if (result is not null && !result.Canceled)
        {
            await ReloadAsync();
        }
    }
}
