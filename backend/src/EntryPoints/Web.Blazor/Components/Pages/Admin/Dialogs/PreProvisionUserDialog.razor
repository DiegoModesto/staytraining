@inject IAdminGatewayClient Client
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="_email" Label="Email" Required="true" />
        <MudTextField @bind-Value="_displayName" Label="Display name" Required="true" />
        <MudTextField @bind-Value="_netSuiteEmail" Label="NetSuite email (optional)" />
        @if (_error is not null)
        {
            <MudAlert Severity="Severity.Error" Class="mt-2">@_error</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="_busy">Create</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    private string _email = "";
    private string _displayName = "";
    private string? _netSuiteEmail;
    private bool _busy;
    private string? _error;

    private async Task Submit()
    {
        _busy = true;
        _error = null;
        try
        {
            Guid id = await Client.PreProvisionUserAsync(_email, _displayName, _netSuiteEmail, CancellationToken.None);
            Snackbar.Add("User pre-provisioned.", Severity.Success);
            MudDialog.Close(DialogResult.Ok(id));
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
