<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="_name" Label="@Label" Required Immediate MaxLength="120" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => Dialog.Cancel())">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">Salvar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance Dialog { get; set; } = default!;

    [Parameter] public string Label { get; set; } = "Nome";
    [Parameter] public string? Initial { get; set; }

    private string _name = string.Empty;

    protected override void OnInitialized() => _name = Initial ?? string.Empty;

    private void Submit()
    {
        if (!string.IsNullOrWhiteSpace(_name))
        {
            Dialog.Close(DialogResult.Ok(_name.Trim()));
        }
    }
}
