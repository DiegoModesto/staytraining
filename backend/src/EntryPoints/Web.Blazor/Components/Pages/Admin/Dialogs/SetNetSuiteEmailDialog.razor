@inject IAdminGatewayClient Client
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="_netSuiteEmail" Label="NetSuite email" />
        @if (_error is not null)
        {
            <MudAlert Severity="Severity.Error" Class="mt-2">@_error</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="_busy">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public Guid UserId { get; set; }
    [Parameter] public string? CurrentNetSuiteEmail { get; set; }

    private string? _netSuiteEmail;
    private bool _busy;
    private string? _error;

    protected override void OnInitialized() => _netSuiteEmail = CurrentNetSuiteEmail;

    private async Task Submit()
    {
        _busy = true;
        _error = null;
        try
        {
            await Client.SetNetSuiteEmailAsync(UserId, string.IsNullOrWhiteSpace(_netSuiteEmail) ? null : _netSuiteEmail, CancellationToken.None);
            Snackbar.Add("NetSuite email updated.", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
