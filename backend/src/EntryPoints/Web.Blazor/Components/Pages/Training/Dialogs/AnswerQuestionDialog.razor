@using Web.Blazor.Training
@inject ITrainingApiClient Api
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-1"><b>@Question.StudentName</b> — @About</MudText>
        <MudText Class="mb-3">@Question.Text</MudText>
        <MudTextField @bind-Value="_answer" Label="Resposta" Lines="3" Required AutoFocus MaxLength="4000" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="_busy">Enviar resposta</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance Dialog { get; set; } = default!;
    [Parameter] public QuestionDto Question { get; set; } = default!;

    private string _answer = string.Empty;
    private bool _busy;

    protected override void OnInitialized() => _answer = Question.AnswerText ?? string.Empty;

    private string About =>
        Question.WorkoutName is not null ? $"Treino: {Question.WorkoutName}"
        : Question.ExerciseName is not null ? $"Exercício: {Question.ExerciseName}"
        : "Geral";

    private void Cancel() => Dialog.Cancel();

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_answer))
        {
            Snackbar.Add("Escreva a resposta.", Severity.Warning);
            return;
        }

        _busy = true;
        try
        {
            await Api.AnswerQuestionAsync(Question.Id, new AnswerQuestionRequest(_answer), CancellationToken.None);
            Snackbar.Add("Resposta enviada.", Severity.Success);
            Dialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Falha: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }
}
