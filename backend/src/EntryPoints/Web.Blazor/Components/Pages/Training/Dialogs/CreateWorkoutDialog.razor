@using Web.Blazor.Training
@inject ITrainingApiClient Api
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="_name" Label="Nome do treino" Required Immediate
                      Class="mb-3" MaxLength="200" />
        <MudSelect T="ExerciseCategory?" @bind-Value="_category" Label="Modalidade" Clearable Class="mb-3">
            <MudSelectItem T="ExerciseCategory?" Value="@((ExerciseCategory?)ExerciseCategory.Musculacao)">Musculação</MudSelectItem>
            <MudSelectItem T="ExerciseCategory?" Value="@((ExerciseCategory?)ExerciseCategory.Funcional)">Funcional</MudSelectItem>
            <MudSelectItem T="ExerciseCategory?" Value="@((ExerciseCategory?)ExerciseCategory.Boxe)">Boxe</MudSelectItem>
            <MudSelectItem T="ExerciseCategory?" Value="@((ExerciseCategory?)ExerciseCategory.Aerobico)">Aeróbico</MudSelectItem>
        </MudSelect>
        <MudTextField @bind-Value="_description" Label="Descrição (opcional)" Lines="2" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" Disabled="_busy"
                   OnClick="Submit">Criar e montar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance Dialog { get; set; } = default!;

    /// <summary>The student's user id (workout owner).</summary>
    [Parameter] public Guid OwnerStudentId { get; set; }

    private string _name = string.Empty;
    private ExerciseCategory? _category;
    private string? _description;
    private bool _busy;

    private void Cancel() => Dialog.Cancel();

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_name))
        {
            Snackbar.Add("Informe o nome do treino.", Severity.Warning);
            return;
        }

        _busy = true;
        try
        {
            var request = new CreateWorkoutRequest(OwnerStudentId, _name.Trim(), _description, _category, []);
            Guid id = await Api.CreateWorkoutAsync(request, CancellationToken.None);
            Dialog.Close(DialogResult.Ok(id));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Falha ao criar treino: {ex.Message}", Severity.Error);
            _busy = false;
        }
    }
}
