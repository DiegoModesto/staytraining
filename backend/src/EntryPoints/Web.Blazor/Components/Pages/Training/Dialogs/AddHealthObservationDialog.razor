@using Web.Blazor.Training
@inject ITrainingApiClient Api
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudSelect @bind-Value="_kind" Label="Tipo" Class="mb-2">
            <MudSelectItem Value="HealthObservationKind.HealthIssue">Problema de saúde</MudSelectItem>
            <MudSelectItem Value="HealthObservationKind.ProfessorNote">Nota do professor (ficha)</MudSelectItem>
        </MudSelect>
        <MudTextField @bind-Value="_title" Label="Título" Required Class="mb-2" />
        <MudTextField @bind-Value="_detail" Label="Detalhe" Lines="3" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="_busy">Salvar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance Dialog { get; set; } = default!;
    [Parameter] public Guid StudentProfileId { get; set; }

    private HealthObservationKind _kind = HealthObservationKind.HealthIssue;
    private string _title = string.Empty;
    private string? _detail;
    private bool _busy;

    private void Cancel() => Dialog.Cancel();

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_title))
        {
            Snackbar.Add("Informe o título.", Severity.Warning);
            return;
        }

        _busy = true;
        try
        {
            await Api.AddHealthObservationAsync(StudentProfileId,
                new AddHealthObservationRequest(_kind, _title, _detail), CancellationToken.None);
            Snackbar.Add("Observação adicionada.", Severity.Success);
            Dialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Falha: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }
}
