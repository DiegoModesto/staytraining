@page "/students/{StudentId:guid}"
@attribute [Authorize]
@using Web.Blazor.Training
@inject ITrainingApiClient Api
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Ficha do aluno</PageTitle>

<PermissionView Permission="student.read">
    @if (_student is null)
    {
        <MudProgressCircular Indeterminate="_loading" />
        @if (!_loading) { <MudAlert Severity="Severity.Warning">Aluno não encontrado.</MudAlert> }
    }
    else
    {
        <MudStack Row AlignItems="AlignItems.Center" Class="mb-1">
            <MudText Typo="Typo.h4">@_student.FullName</MudText>
            <MudSpacer />
            <PermissionView Permission="studentficha.write">
                <MudButton StartIcon="@Icons.Material.Filled.Edit" OnClick="OpenEditFicha">Editar ficha</MudButton>
                <MudButton StartIcon="@Icons.Material.Filled.History" OnClick="OpenLogs">Histórico</MudButton>
            </PermissionView>
            <PermissionView Permission="workout.read">
                <MudButton StartIcon="@Icons.Material.Filled.CalendarMonth"
                           OnClick="@(() => Nav.NavigateTo($"/students/{StudentId}/schedule"))">Agenda</MudButton>
            </PermissionView>
            <PermissionView Permission="report.read">
                <MudButton StartIcon="@Icons.Material.Filled.Assessment"
                           OnClick="@(() => Nav.NavigateTo($"/students/{StudentId}/report"))">Relatório semanal</MudButton>
            </PermissionView>
        </MudStack>

        <MudTabs Elevation="0" Rounded="true" Border="true" ApplyEffectsToContainer="true" PanelClass="pa-4">
            <MudTabPanel Text="Ficha" Icon="@Icons.Material.Filled.Badge">
                <MudStack Row AlignItems="AlignItems.Center" Spacing="3" Class="mb-4">
                    <MudAvatar Style="height:64px;width:64px">
                        @if (!string.IsNullOrEmpty(_student.PhotoUrl))
                        {
                            <MudImage Src="@_student.PhotoUrl" />
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Person" />
                        }
                    </MudAvatar>
                    <div>
                        <MudText Typo="Typo.body2">@_student.Email</MudText>
                        @if (!string.IsNullOrWhiteSpace(_student.Phone))
                        {
                            <MudText Typo="Typo.body2">📞 @_student.Phone</MudText>
                        }
                        @if (!string.IsNullOrWhiteSpace(_student.EmergencyPhone))
                        {
                            <MudText Typo="Typo.body2">🚑 @_student.EmergencyPhone</MudText>
                        }
                        <MudStack Row Spacing="1" Class="mt-1">
                            @if (_student.BloodType != BloodType.Unknown)
                            {
                                <MudChip T="string" Size="Size.Small">@BloodTypeDisplay.Label(_student.BloodType)</MudChip>
                            }
                            @if (_student.HeightCm is int h)
                            {
                                <MudChip T="string" Size="Size.Small">@h cm</MudChip>
                            }
                            @if (_student.WeightKg is decimal wkg)
                            {
                                <MudChip T="string" Size="Size.Small">@wkg.ToString("0.#") kg</MudChip>
                            }
                        </MudStack>
                    </div>
                </MudStack>
                @if (!string.IsNullOrWhiteSpace(_student.Goals))
                {
                    <MudAlert Severity="Severity.Info" Class="mb-4">@_student.Goals</MudAlert>
                }

                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudCard>
                            <MudCardHeader>
                                <CardHeaderContent><MudText Typo="Typo.h6">Apontamentos de saúde</MudText></CardHeaderContent>
                                <CardHeaderActions>
                                    <PermissionView Permission="studentficha.write">
                                        <MudIconButton Icon="@Icons.Material.Filled.Add" OnClick="OpenAddApportment" />
                                    </PermissionView>
                                </CardHeaderActions>
                            </MudCardHeader>
                            <MudCardContent>
                                @if (_student.HealthApportments.Count == 0)
                                {
                                    <MudText Typo="Typo.body2">Sem apontamentos.</MudText>
                                }
                                else
                                {
                                    <MudList T="HealthApportmentDto" Dense>
                                        @foreach (var a in _student.HealthApportments)
                                        {
                                            <MudListItem T="HealthApportmentDto" Icon="@Icons.Material.Filled.HealthAndSafety">
                                                <MudStack Row AlignItems="AlignItems.Center">
                                                    <div style="flex:1">
                                                        <MudText Typo="Typo.subtitle2">@a.BodyPartName: @a.ProblemTypeName</MudText>
                                                        @if (!string.IsNullOrWhiteSpace(a.Observation))
                                                        {
                                                            <MudText Typo="Typo.body2">Obs: @a.Observation</MudText>
                                                        }
                                                    </div>
                                                    <PermissionView Permission="studentficha.write">
                                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                                       Color="Color.Error" OnClick="@(() => RemoveApportment(a))" />
                                                    </PermissionView>
                                                </MudStack>
                                            </MudListItem>
                                        }
                                    </MudList>
                                }
                            </MudCardContent>
                        </MudCard>
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudCard>
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6">Anotações do aluno</MudText>
                                    <MudText Typo="Typo.caption">Gerais — visíveis a todos os professores, nunca ao aluno.</MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <PermissionView Permission="student.read">
                                        <MudButton Size="Size.Small" StartIcon="@Icons.Material.Filled.EditNote"
                                                   Color="Color.Primary" OnClick="OpenAddNote">Nova anotação</MudButton>
                                    </PermissionView>
                                </CardHeaderActions>
                            </MudCardHeader>
                            <MudCardContent>
                                @{ var generalNotes = _notes.Where(n => n.WorkoutId is null).ToList(); }
                                @if (generalNotes.Count == 0)
                                {
                                    <MudText Typo="Typo.body2">Sem anotações.</MudText>
                                }
                                else
                                {
                                    <MudList T="StudentNoteDto" Dense>
                                        @foreach (var n in generalNotes)
                                        {
                                            <MudListItem T="StudentNoteDto" Icon="@Icons.Material.Filled.StickyNote2">
                                                <MudText Typo="Typo.body1">@n.Content</MudText>
                                                <MudText Typo="Typo.caption">
                                                    @n.AuthorName · @n.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                                </MudText>
                                            </MudListItem>
                                        }
                                    </MudList>
                                }
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                </MudGrid>
            </MudTabPanel>

            <MudTabPanel Text="Treinos" Icon="@Icons.Material.Filled.FitnessCenter">
                <MudStack Row AlignItems="AlignItems.Center" Class="mb-3">
                    <MudSpacer />
                    <PermissionView Permission="workout.write">
                        <MudButton Size="Size.Small" StartIcon="@Icons.Material.Filled.Add"
                                   Color="Color.Primary" OnClick="OpenCreateWorkout">Novo treino</MudButton>
                        <MudButton Size="Size.Small" StartIcon="@Icons.Material.Filled.ContentCopy"
                                   OnClick="OpenAssignTemplate">De modelo</MudButton>
                    </PermissionView>
                </MudStack>

                @if (_workouts.Count == 0)
                {
                    <MudText Typo="Typo.body2">Nenhum treino atribuído.</MudText>
                }
                else
                {
                    @foreach (var w in _workouts)
                    {
                        var workoutNotes = _notes.Where(n => n.WorkoutId == w.Id).ToList();
                        <MudCard Class="mb-3">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudStack Row AlignItems="AlignItems.Center">
                                        <MudIcon Icon="@Icons.Material.Filled.FitnessCenter" />
                                        <MudText Typo="Typo.subtitle1" Style="cursor:pointer"
                                                 @onclick="@(() => OpenWorkout(w.Id))">@w.Name</MudText>
                                        <MudChip T="string" Size="Size.Small">@w.ItemCount ex.</MudChip>
                                    </MudStack>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudButton Size="Size.Small" Variant="Variant.Outlined"
                                               OnClick="@(() => OpenWorkout(w.Id))">Abrir</MudButton>
                                    <PermissionView Permission="student.read">
                                        <MudButton Size="Size.Small" StartIcon="@Icons.Material.Filled.EditNote"
                                                   OnClick="@(() => OpenAddWorkoutNote(w.Id))">Anotação</MudButton>
                                    </PermissionView>
                                    <PermissionView Permission="workout.write">
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                       Color="Color.Error" OnClick="@(() => DeleteWorkout(w.Id, w.Name))" />
                                    </PermissionView>
                                </CardHeaderActions>
                            </MudCardHeader>
                            <MudCardContent>
                                @if (workoutNotes.Count == 0)
                                {
                                    <MudText Typo="Typo.body2" Style="color:var(--mud-palette-text-secondary)">
                                        Sem anotações neste treino.
                                    </MudText>
                                }
                                else
                                {
                                    <MudList T="StudentNoteDto" Dense>
                                        @foreach (var n in workoutNotes)
                                        {
                                            <MudListItem T="StudentNoteDto" Icon="@Icons.Material.Filled.StickyNote2">
                                                <MudText Typo="Typo.body1">@n.Content</MudText>
                                                <MudText Typo="Typo.caption">
                                                    @n.AuthorName · @n.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                                </MudText>
                                            </MudListItem>
                                        }
                                    </MudList>
                                }
                            </MudCardContent>
                        </MudCard>
                    }
                }
            </MudTabPanel>
        </MudTabs>
    }
</PermissionView>

@code {
    [Parameter] public Guid StudentId { get; set; }

    private StudentDetailDto? _student;
    private IReadOnlyList<WorkoutListItemDto> _workouts = [];
    private IReadOnlyList<StudentNoteDto> _notes = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _student = await Api.GetStudentAsync(StudentId, CancellationToken.None);
            if (_student is not null)
            {
                _workouts = await Api.ListWorkoutsAsync(_student.UserId, CancellationToken.None);
                _notes = await Api.ListStudentNotesAsync(StudentId, CancellationToken.None);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Falha ao carregar ficha: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OpenAddApportment()
    {
        IDialogReference dlg = await DialogService.ShowAsync<Dialogs.ApportmentDialog>("Novo apontamento de saúde");
        DialogResult? r = await dlg.Result;
        if (r is null || r.Canceled || r.Data is not AddApportmentRequest req)
        {
            return;
        }

        try
        {
            await Api.AddStudentApportmentAsync(StudentId, req, CancellationToken.None);
            Snackbar.Add("Apontamento adicionado.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Falha ao adicionar apontamento: {ex.Message}", Severity.Error);
        }
    }

    private async Task RemoveApportment(HealthApportmentDto apport)
    {
        bool? confirm = await DialogService.ShowMessageBox(
            "Remover apontamento",
            $"Remover \"{apport.BodyPartName}: {apport.ProblemTypeName}\"?",
            yesText: "Remover", cancelText: "Cancelar");
        if (confirm != true)
        {
            return;
        }

        try
        {
            await Api.RemoveStudentApportmentAsync(StudentId, apport.Id, CancellationToken.None);
            Snackbar.Add("Apontamento removido.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Falha ao remover: {ex.Message}", Severity.Error);
        }
    }

    private async Task OpenEditFicha()
    {
        if (_student is null)
        {
            return;
        }

        var parameters = new DialogParameters<Dialogs.StudentFichaDialog> { { x => x.Student, _student } };
        IDialogReference dlg = await DialogService.ShowAsync<Dialogs.StudentFichaDialog>("Editar ficha", parameters);
        DialogResult? r = await dlg.Result;
        if (r is null || r.Canceled || r.Data is not UpdateStudentFichaRequest req)
        {
            return;
        }

        try
        {
            await Api.UpdateStudentFichaAsync(StudentId, req, CancellationToken.None);
            Snackbar.Add("Ficha atualizada.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Falha ao atualizar ficha: {ex.Message}", Severity.Error);
        }
    }

    private async Task OpenLogs()
    {
        var parameters = new DialogParameters<Dialogs.StudentEditLogsDialog> { { x => x.StudentProfileId, StudentId } };
        await DialogService.ShowAsync<Dialogs.StudentEditLogsDialog>("Histórico de edições", parameters);
    }

    private Task OpenAddNote() => AddNote(null);

    private Task OpenAddWorkoutNote(Guid workoutId) => AddNote(workoutId);

    private async Task AddNote(Guid? workoutId)
    {
        var parameters = new DialogParameters<Dialogs.AddStudentNoteDialog>
        {
            { x => x.StudentProfileId, StudentId },
            { x => x.WorkoutId, workoutId },
        };
        string title = workoutId is null ? "Nova anotação" : "Anotação do treino";
        IDialogReference dlg = await DialogService.ShowAsync<Dialogs.AddStudentNoteDialog>(title, parameters);
        DialogResult? r = await dlg.Result;
        if (r is not null && !r.Canceled) await LoadAsync();
    }

    private void OpenWorkout(Guid workoutId) =>
        Nav.NavigateTo($"/workouts/{workoutId}?from={Uri.EscapeDataString($"/students/{StudentId}")}");

    private async Task OpenCreateWorkout()
    {
        if (_student is null) return;
        var parameters = new DialogParameters<Dialogs.CreateWorkoutDialog>
        {
            { x => x.OwnerStudentId, _student.UserId },
        };
        IDialogReference dlg = await DialogService.ShowAsync<Dialogs.CreateWorkoutDialog>("Novo treino", parameters);
        DialogResult? r = await dlg.Result;
        if (r is not null && !r.Canceled && r.Data is Guid id)
        {
            Nav.NavigateTo($"/workouts/{id}?from={Uri.EscapeDataString($"/students/{StudentId}")}");
        }
    }

    private async Task OpenAssignTemplate()
    {
        if (_student is null) return;
        var parameters = new DialogParameters<Dialogs.AssignTemplateDialog>
        {
            { x => x.OwnerStudentId, _student.UserId },
        };
        IDialogReference dlg = await DialogService.ShowAsync<Dialogs.AssignTemplateDialog>("Atribuir treino de modelo", parameters);
        DialogResult? r = await dlg.Result;
        if (r is not null && !r.Canceled) await LoadAsync();
    }

    private async Task DeleteWorkout(Guid workoutId, string name)
    {
        bool? confirmed = await DialogService.ShowMessageBox(
            "Excluir treino",
            $"Excluir o treino \"{name}\"? Esta ação não pode ser desfeita.",
            yesText: "Excluir", cancelText: "Cancelar");
        if (confirmed != true) return;

        try
        {
            await Api.DeleteWorkoutAsync(workoutId, CancellationToken.None);
            Snackbar.Add("Treino excluído.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Falha ao excluir treino: {ex.Message}", Severity.Error);
        }
    }
}
